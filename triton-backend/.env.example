# Environment variables for Triton Backend

# Logging
# Default is quiet: warnings and errors only, no Uvicorn access log, no SQL echo.
# Set BACKEND_VERBOSE=true for info-level application logs and Uvicorn access logs.
# Set LOG_LEVEL=DEBUG for deeper debugging. Set DATABASE_ECHO=1 to log SQL.
BACKEND_VERBOSE=false
# LOG_LEVEL=WARNING
# LOG_FORMAT=%(asctime)s %(levelname)s [%(name)s] %(message)s
# DATABASE_ECHO=0

# Database Configuration
DATABASE_URL=postgresql://triton:tritonpw@localhost:5433/triton_backend
# For local Postgres TLS with certificate verification, use:
# DATABASE_URL=postgresql://triton:tritonpw@localhost:5433/triton_backend?sslmode=verify-full&sslrootcert=/absolute/path/to/triton-backend/tls/rootCA.pem

# Optional in OIDC_CONFIG_SOURCE=env: dedicated CA bundle for OIDC discovery/token validation.
# Env mode always reads the OIDC certificate from this file path. DB mode uses the
# certificate stored through the web UI and does not read OIDC_CA_BUNDLE.
# OIDC_CA_BUNDLE=/tls/rootCA.pem

# Triton Server
TRITON_SERVER_URL=http://localhost:8888
# Timeout, in seconds, for validating a Triton URL when creating or editing an instance.
# Lower values keep the UI from staying in "Saving..." too long for unreachable URLs.
TRITON_CONNECTION_VALIDATION_TIMEOUT_SECONDS=5
# Interval, in seconds, for the background poller that refreshes instance health,
# metrics, and model repository snapshots in the database.
TRITON_HEALTH_REFRESH_INTERVAL_SECONDS=10
# Direct Triton HTTP calls ignore HTTP_PROXY/HTTPS_PROXY by default so local
# Minikube hosts-file names such as *.localtest.me are reached directly.
# Set true only if Triton endpoints must be reached through environment proxies.
TRITON_HTTP_TRUST_ENV=false

# Kubernetes API access for Triton deployments and Perf Analyzer management.
# Set a kubeconfig file path only for local testing of Triton Control itself when backend runs outside Kubernetes.
# Do not use KUBERNETES_KUBECONFIG_PATH for stage/dev shared environments or in-cluster production deployments.
# Leave empty when the backend runs in a cluster and should use its ServiceAccount.
# Development only: enable/disable Kubernetes integration explicitly.
#KUBERNETES_ENABLED=true
#KUBERNETES_KUBECONFIG_PATH=

# Image for vLLM repository init containers and sidecars created in Kubernetes.
# This is read by the host backend process; the image itself runs in Kubernetes.
# Non-vLLM deployments use native Triton S3 and ignore this setting.
TRITON_DEPLOY_S3_SYNC_IMAGE=amazon/aws-cli:2.22.35

# Optional: override the local source directory for the Development Triton Deploy extension.
# Needed mainly when the backend runs outside the Docker image and cannot find the
# repository's code-server-extensions/triton-deploy directory automatically.
# Prefer forward slashes on Windows to avoid backslash escape surprises in .env parsing.
#TRITON_DEPLOY_CODE_SERVER_EXTENSION_DIR=C:/Users/ghost/git/triton-control/code-server-extensions/triton-deploy

# --------------------
# OIDC (BFF)
# --------------------
# OIDC configuration source: `db` (API-managed) or `env` (env-managed, read-only via API)
OIDC_CONFIG_SOURCE=db

OIDC_ENABLED=false


# Explicit issuer for env mode.
OIDC_ISSUER=http://localhost:8080/realms/master

# Create an OIDC confidential client and paste credentials here
OIDC_CLIENT_ID=triton-fastapi
OIDC_CLIENT_SECRET=change-me

# Public backend URL that the OIDC provider can redirect back to
# (Must match your OIDC client's valid redirect URIs)
APP_BASE_URL=https://127.0.0.1:8000

# Runtime callback URL for OIDC. This value is env-driven at runtime
# and takes precedence over any value stored in DB settings.
OIDC_REDIRECT_URI=https://127.0.0.1:8000/auth/callback

# Optional: change requested scopes
OIDC_SCOPE=openid profile email

# Env mode only: set false to pass verify=False to OIDC httpx clients.
# In DB mode the web UI SSL checkbox controls this instead.
OIDC_SSL_VERIFY=false

# Where the browser should land after login success (Angular)
FRONTEND_REDIRECT_URL=https://127.0.0.1:4200




# Optional: first OIDC admin bootstrap allowlist (comma-separated emails)
# If set, only listed users can become the first auto-bootstrapped OIDC admin
OIDC_ADMIN_EMAILS=

# --------------------
# Session cookie config
# --------------------
# IMPORTANT: SessionMiddleware stores session data in a signed cookie (not encrypted).
# Keep it small and DO NOT store access/refresh tokens.
SESSION_SECRET=change-me-please
SESSION_COOKIE=session
SESSION_SAMESITE=lax

# Set true when browsers access the backend via HTTPS, including behind an HTTPS ingress/proxy
SESSION_HTTPS_ONLY=false
# Optional session lifetime in seconds (default: 1209600 = 14 days)
# SESSION_MAX_AGE_SECONDS=1209600

# Set true only when Uvicorn serves HTTPS directly. Keep false behind an HTTPS ingress/proxy.
SERVER_HTTPS_ENABLED=false

# Uvicorn HTTPS certificate files, used only when SERVER_HTTPS_ENABLED=true
TLS_KEY_FILE=./tls/key.pem
TLS_CERT_FILE=./tls/cert.pem

# --------------------
# Local auth / JWT
# --------------------
# Use a strong random secret in production.
JWT_SECRET=change-me-jwt
# Local JWT access token lifetime in minutes (default: 60)
# JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60

# --------------------
# S3 secret encryption
# --------------------
# Fernet key for encrypting S3 secret keys (generate with Python: Fernet.generate_key()).
S3_SECRET_ENCRYPTION_KEY=change-me-s3

# --------------------
# CORS (Angular dev server)
# --------------------
# Comma-separated list
CORS_ORIGINS=https://127.0.0.1:4200,https://localhost:4200,http://127.0.0.1:4200,http://localhost:4200
